@page "/contact"

<PageTitle>Contact | Ben McNees</PageTitle>

<div class="contact-page">
    <section class="contact-hero" aria-labelledby="contact-heading">
        <div>
            <p class="eyebrow">Contact</p>
            <h1 id="contact-heading">Let's talk.</h1>
            <p class="contact-lede">
                Reach out about software projects, technical collaboration, portfolio feedback, or work that
                needs practical engineering judgment across .NET, web, desktop, or game systems.
            </p>
        </div>

        <aside class="contact-card" aria-label="Primary contact methods">
            <a class="contact-link primary" href="mailto:mcneesbr@gmail.com">
                <span>Email</span>
                <strong>mcneesbr@gmail.com</strong>
            </a>

            <a class="contact-link" href="https://github.com/Banjomann" target="_blank" rel="noopener noreferrer">
                <span>GitHub</span>
                <strong>github.com/Banjomann</strong>
            </a>
        </aside>
    </section>

    <section class="contact-section" aria-labelledby="contact-context-heading">
        <div class="section-heading">
            <p class="eyebrow">Good fits</p>
            <h2 id="contact-context-heading">The kinds of conversations worth starting.</h2>
        </div>

        <div class="contact-context-grid">
            <article>
                <h3>Application work</h3>
                <p>Architecture, implementation planning, UI workflows, backend contracts, or .NET app direction.</p>
            </article>
            <article>
                <h3>Technical portfolio</h3>
                <p>Questions about Vivid, Banjo, TimeKeeper, or the engineering decisions behind this site.</p>
            </article>
            <article>
                <h3>Focused collaboration</h3>
                <p>Small tools, debugging, code review, automation, and practical feature work with clear goals.</p>
            </article>
        </div>
    </section>
</div>
